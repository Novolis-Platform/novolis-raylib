{
  "schemaVersion": 1,
  "description": "Machine-readable registry for AI agents. Run these tools instead of hand-editing generated output.",
  "generated": {
    "globs": [
      "src/Novolis.Raylib.Bindings/Interop/*.g.cs",
      "src/Novolis.Raylib.Runtime/**/*.g.cs"
    ],
    "marker": "<auto-generated />",
    "sourceOfTruth": "pipeline/raylib6/*.manifest.json",
    "handEditAllowed": [
      "codegen/Novolis.Raylib.CodeGen/**",
      "codegen/Novolis.Raylib.CodeGen.Hooks/**",
      "codegen/Novolis.Raylib.Pipeline/**"
    ]
  },
  "tools": [
    {
      "id": "pipeline.run",
      "title": "Run maintainer pipeline profile or step",
      "command": "dotnet run --project codegen/Novolis.Raylib.Pipeline -- run maintainer",
      "runWhen": [
        "Fetch vendor sources or build native shims",
        "Full maintainer refresh"
      ]
    },
    {
      "id": "codegen.generate",
      "title": "Regenerate all bindings",
      "command": "dotnet run --project codegen/Novolis.Raylib.Pipeline -- run generate",
      "runWhen": [
        "Changed any file under pipeline/raylib6/*.manifest.json",
        "Added or changed IRaylibCodegenHook",
        "Before committing binding or façade work"
      ],
      "outputs": [
        "src/Novolis.Raylib.Bindings/Interop/*.g.cs",
        "src/Novolis.Raylib.Runtime/**/*.g.cs"
      ]
    },
    {
      "id": "codegen.verify",
      "title": "Verify raylib manifest vs vendor headers",
      "command": "dotnet run --project codegen/Novolis.Raylib.CodeGen -- verify"
    },
    {
      "id": "codegen.drift-check",
      "title": "Regenerate and fail if committed output differs (CI parity)",
      "command": "pwsh ./scripts/raylib-codegen-check.ps1",
      "platforms": ["windows", "linux", "macos"]
    },
    {
      "id": "codegen.suggest-raylib",
      "title": "List RLAPI symbols in vendor raylib.h missing from manifest",
      "command": "dotnet run --project codegen/Novolis.Raylib.CodeGen -- suggest-raylib"
    },
    {
      "id": "codegen.hooks-list",
      "title": "List registered Roslyn codegen hooks",
      "command": "dotnet run --project codegen/Novolis.Raylib.CodeGen -- hooks list"
    },
    {
      "id": "pipeline.all",
      "title": "Maintainer pipeline: fetch + native + codegen + drift",
      "command": "dotnet run --project codegen/Novolis.Raylib.Pipeline -- run maintainer"
    },
    {
      "id": "agent.verify",
      "title": "Agent gate: codegen drift + build Bindings and Runtime",
      "command": "pwsh ./scripts/agent-verify.ps1",
      "runWhen": ["Before marking binding/codegen tasks complete", "After editing manifests or hooks"]
    },
    {
      "id": "golden.run",
      "title": "Run golden image tests (native + QA reports)",
      "command": "pwsh ./scripts/run-golden-tests.ps1",
      "platforms": ["windows"]
    },
    {
      "id": "golden.seed-baselines",
      "title": "Regenerate committed golden baseline PNGs and spec hashes",
      "command": "pwsh ./scripts/seed-golden-baselines.ps1",
      "platforms": ["windows"]
    }
  ],
  "workflows": {
    "add-raylib-export": [
      "Edit pipeline/raylib6/raylib-exports.manifest.json (and facades/hud/gui manifest if needed)",
      "Run tool codegen.generate",
      "Run tool agent.verify",
      "Commit manifest + *.g.cs + pipeline/raylib6/steps/*/result.json and step.log when maintainer ran full pipeline"
    ],
    "add-facade-method": [
      "Edit pipeline/raylib6/facades.manifest.json (or hud.manifest.json / gui.manifest.json / raygui.manifest.json)",
      "Run tool codegen.generate",
      "Run tool agent.verify"
    ],
    "customize-emitted-csharp": [
      "Add or change IRaylibCodegenHook in codegen/Novolis.Raylib.CodeGen.Hooks/",
      "Run tool codegen.generate",
      "Run tool agent.verify"
    ],
    "refresh-golden-baselines": [
      "Run tool golden.seed-baselines",
      "Open temp/test-renders QA reports and verify expectations",
      "Commit tests/Novolis.Raylib.Golden/Goldens/**"
    ]
  },
  "docs": [
    "AGENTS.md",
    "docs/codegen.md",
    "agentic-tools/README.md",
    "agentic-tools/workflows/codegen.md"
  ]
}
