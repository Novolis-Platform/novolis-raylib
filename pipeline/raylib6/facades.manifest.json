{
  "types": [
    {
      "name": "Graphics",
      "namespace": "Novolis.Raylib.Rendering",
      "folder": "Rendering",
      "typeSummary": "2D drawing and framebuffer operations (raylib drawing module).",
      "usings": [
        "System.Drawing",
        "Novolis.Raylib.Interop"
      ],
      "methods": [
        {
          "name": "BeginDrawing",
          "signature": "void BeginDrawing()",
          "body": "Raylib6Native.BeginDrawing()",
          "summary": "Setup canvas (framebuffer) to start drawing"
        },
        {
          "name": "EndDrawing",
          "signature": "void EndDrawing()",
          "body": "Raylib6Native.EndDrawing()",
          "summary": "End canvas drawing and swap buffers (double buffering)"
        },
        {
          "name": "ClearBackground",
          "signature": "void ClearBackground(Color color)",
          "body": "Raylib6Native.ClearBackground(color.ToRaylibColor())",
          "summary": "Set background color (framebuffer clear color)"
        },
        {
          "name": "DrawText",
          "signature": "void DrawText(string text, int posX, int posY, int fontSize, Color color)",
          "body": "Raylib6Native.DrawText(text, posX, posY, fontSize, color.ToRaylibColor())",
          "summary": "Draw text (using default font)"
        },
        {
          "name": "MeasureText",
          "signature": "int MeasureText(string text, int fontSize)",
          "body": "Raylib6Native.MeasureText(text, fontSize)",
          "summary": "Measure string width for default font"
        },
        {
          "name": "DrawRectangle",
          "signature": "void DrawRectangle(int posX, int posY, int width, int height, Color color)",
          "body": "Raylib6Native.DrawRectangle(posX, posY, width, height, color.ToRaylibColor())",
          "summary": "Draw a color-filled rectangle"
        },
        {
          "name": "DrawRectangleRec",
          "signature": "void DrawRectangleRec(RectangleF rec, Color color)",
          "body": "Raylib6Native.DrawRectangleRec(rec, color.ToRaylibColor())",
          "summary": "Draw a color-filled rectangle"
        },
        {
          "name": "DrawRectangleLines",
          "signature": "void DrawRectangleLines(int posX, int posY, int width, int height, Color color)",
          "body": "Raylib6Native.DrawRectangleLines(posX, posY, width, height, color.ToRaylibColor())",
          "summary": "Draw rectangle outline"
        },
        {
          "name": "DrawLine",
          "signature": "void DrawLine(int startPosX, int startPosY, int endPosX, int endPosY, Color color)",
          "body": "Raylib6Native.DrawLine(startPosX, startPosY, endPosX, endPosY, color.ToRaylibColor())",
          "summary": "Draw a line"
        },
        {
          "name": "BeginScissorMode",
          "signature": "void BeginScissorMode(int x, int y, int width, int height)",
          "body": "Raylib6Native.BeginScissorMode(x, y, width, height)",
          "summary": "Begin scissor mode (define screen area for following drawing)"
        },
        {
          "name": "EndScissorMode",
          "signature": "void EndScissorMode()",
          "body": "Raylib6Native.EndScissorMode()",
          "summary": "End scissor mode"
        },
        {
          "name": "DrawCircle",
          "signature": "void DrawCircle(int centerX, int centerY, float radius, Color color)",
          "body": "Raylib6Native.DrawCircle(centerX, centerY, radius, color.ToRaylibColor())",
          "summary": "Draw a color-filled circle"
        },
        {
          "name": "DrawFPS",
          "signature": "void DrawFPS(int posX, int posY)",
          "body": "Raylib6Native.DrawFPS(posX, posY)",
          "summary": "Draw current FPS"
        }
      ]
    },
    {
      "name": "Window",
      "namespace": "Novolis.Raylib.Windowing",
      "folder": "Windowing",
      "typeSummary": "Window lifecycle, configuration, and display state.",
      "usings": [
        "Novolis.Raylib.Interop",
        "Novolis.Raylib.Interact"
      ],
      "methods": [
        {
          "name": "SetConfigFlags",
          "signature": "void SetConfigFlags(uint flags)",
          "body": "Raylib6Native.SetConfigFlags(flags)",
          "summary": "raylib SetConfigFlags \u2014 call before Init for pre-window flags (e.g. WindowStateFlags.Hidden / FLAG_WINDOW_HIDDEN)."
        },
        {
          "name": "Init",
          "signature": "void Init(int width, int height, string title)",
          "body": "Raylib6Native.InitWindow(width, height, title)",
          "summary": "Initialize window and OpenGL context"
        },
        {
          "name": "ShouldClose",
          "signature": "bool ShouldClose()",
          "body": "Raylib6Native.WindowShouldClose()",
          "summary": "Check if application should close (KEY_ESCAPE pressed or windows close icon clicked)"
        },
        {
          "name": "Close",
          "signature": "void Close()",
          "body": "Raylib6Native.CloseWindow()",
          "summary": "Close window and unload OpenGL context"
        },
        {
          "name": "IsReady",
          "signature": "bool IsReady()",
          "body": "Raylib6Native.IsWindowReady()",
          "summary": "Check if window has been initialized successfully"
        },
        {
          "name": "IsHidden",
          "signature": "bool IsHidden()",
          "body": "Raylib6Native.IsWindowHidden()",
          "summary": "Check if window is currently hidden"
        },
        {
          "name": "GetScreenWidth",
          "signature": "int GetScreenWidth()",
          "body": "Raylib6Native.GetScreenWidth()",
          "summary": "Get current screen width"
        },
        {
          "name": "GetScreenHeight",
          "signature": "int GetScreenHeight()",
          "body": "Raylib6Native.GetScreenHeight()",
          "summary": "Get current screen height"
        },
        {
          "name": "SetTitle",
          "signature": "void SetTitle(string title)",
          "body": "Raylib6Native.SetWindowTitle(title)",
          "summary": "Set title for window"
        },
        {
          "name": "ToggleFullscreen",
          "signature": "void ToggleFullscreen()",
          "body": "Raylib6Native.ToggleFullscreen()",
          "summary": "Toggle window state: fullscreen/windowed, resizes monitor to match window resolution"
        },
        {
          "name": "IsFullscreen",
          "signature": "bool IsFullscreen()",
          "body": "Raylib6Native.IsWindowFullscreen()",
          "summary": "Check if window is currently fullscreen"
        },
        {
          "name": "SetState",
          "signature": "void SetState(uint flags)",
          "body": "Raylib6Native.SetWindowState(flags)",
          "summary": "raylib SetWindowState (e.g. FLAG_WINDOW_RESIZABLE from raylib headers)."
        },
        {
          "name": "PollInputEvents",
          "signature": "void PollInputEvents()",
          "body": "Raylib6Native.PollInputEvents()",
          "summary": "Register all input events"
        },
        {
          "name": "SetExitKey",
          "signature": "void SetExitKey(KeyboardKey key)",
          "body": "Raylib6Native.SetExitKey((int)key)",
          "summary": "Sets the key that closes the window (default Escape / KeyboardKey.Escape)."
        }
      ]
    },
    {
      "name": "Input",
      "namespace": "Novolis.Raylib.Interact",
      "folder": "Interact",
      "typeSummary": "Keyboard, mouse, and cursor input.",
      "usings": [
        "System.Numerics",
        "Novolis.Raylib.Interop"
      ],
      "methods": [
        {
          "name": "IsKeyPressed",
          "signature": "bool IsKeyPressed(KeyboardKey key)",
          "body": "Raylib6Native.IsKeyPressed((int)key)",
          "summary": "Check if a key has been pressed once"
        },
        {
          "name": "IsKeyDown",
          "signature": "bool IsKeyDown(KeyboardKey key)",
          "body": "Raylib6Native.IsKeyDown((int)key)",
          "summary": "Check if a key is being pressed"
        },
        {
          "name": "IsKeyReleased",
          "signature": "bool IsKeyReleased(KeyboardKey key)",
          "body": "Raylib6Native.IsKeyReleased((int)key)",
          "summary": "Check if a key has been released once"
        },
        {
          "name": "GetCharPressed",
          "signature": "int GetCharPressed()",
          "body": "Raylib6Native.GetCharPressed()",
          "summary": "Unicode codepoint from the last key pressed with Alt or Ctrl (raylib GetCharPressed)."
        },
        {
          "name": "GetKeyPressed",
          "signature": "int GetKeyPressed()",
          "body": "Raylib6Native.GetKeyPressed()",
          "summary": "Next keycode from the key queue (raylib GetKeyPressed); returns 0 when empty."
        },
        {
          "name": "IsCursorOnScreen",
          "signature": "bool IsCursorOnScreen()",
          "body": "Raylib6Native.IsCursorOnScreen()",
          "summary": "Check if cursor is on the screen"
        },
        {
          "name": "IsMouseButtonPressed",
          "signature": "bool IsMouseButtonPressed(MouseButton button)",
          "body": "Raylib6Native.IsMouseButtonPressed((int)button)",
          "summary": "Check if a mouse button has been pressed once"
        },
        {
          "name": "IsMouseButtonDown",
          "signature": "bool IsMouseButtonDown(MouseButton button)",
          "body": "Raylib6Native.IsMouseButtonDown((int)button)",
          "summary": "Check if a mouse button is being pressed"
        },
        {
          "name": "GetMouseWheelMove",
          "signature": "float GetMouseWheelMove()",
          "body": "Raylib6Native.GetMouseWheelMove()",
          "summary": "Get mouse wheel movement for X or Y, whichever is larger"
        },
        {
          "name": "GetMousePosition",
          "signature": "Vector2 GetMousePosition()",
          "body": "Raylib6Native.GetMousePosition()",
          "summary": "Get mouse position XY"
        },
        {
          "name": "GetMouseDelta",
          "signature": "Vector2 GetMouseDelta()",
          "body": "Raylib6Native.GetMouseDelta()",
          "summary": "Get mouse delta between frames"
        },
        {
          "name": "DisableCursor",
          "signature": "void DisableCursor()",
          "body": "Raylib6Native.DisableCursor()",
          "summary": "Disables cursor (lock cursor)"
        },
        {
          "name": "EnableCursor",
          "signature": "void EnableCursor()",
          "body": "Raylib6Native.EnableCursor()",
          "summary": "Enables cursor (unlock cursor)"
        },
        {
          "name": "SetMousePosition",
          "signature": "void SetMousePosition(int x, int y)",
          "body": "Raylib6Native.SetMousePosition(x, y)",
          "summary": "Set mouse position XY"
        }
      ]
    },
    {
      "name": "World",
      "namespace": "Novolis.Raylib.Rendering",
      "folder": "Rendering",
      "typeSummary": "3D scene rendering; call Begin with a Camera, then draw, then End.",
      "usings": [
        "System.Drawing",
        "System.Numerics",
        "Novolis.Raylib.Interop"
      ],
      "methods": [
        {
          "name": "Begin",
          "signature": "void Begin(Camera camera)",
          "body": "Raylib6Native.BeginMode3D(camera)",
          "summary": "Begin 3D mode with custom camera (3D)"
        },
        {
          "name": "End",
          "signature": "void End()",
          "body": "Raylib6Native.EndMode3D()",
          "summary": "Ends 3D mode and returns to default 2D orthographic mode"
        },
        {
          "name": "DrawCube",
          "signature": "void DrawCube(Vector3 position, float width, float height, float length, Color color)",
          "body": "Raylib6Native.DrawCube(position, width, height, length, color.ToRaylibColor())",
          "summary": "Draw cube"
        },
        {
          "name": "DrawCubeV",
          "signature": "void DrawCubeV(Vector3 position, Vector3 size, Color color)",
          "body": "Raylib6Native.DrawCubeV(position, size, color.ToRaylibColor())",
          "summary": "Draw cube (Vector version)"
        },
        {
          "name": "DrawCubeWiresV",
          "signature": "void DrawCubeWiresV(Vector3 position, Vector3 size, Color color)",
          "body": "Raylib6Native.DrawCubeWiresV(position, size, color.ToRaylibColor())",
          "summary": "Draw cube wires (Vector version)"
        },
        {
          "name": "DrawSphere",
          "signature": "void DrawSphere(Vector3 centerPos, float radius, Color color)",
          "body": "Raylib6Native.DrawSphere(centerPos, radius, color.ToRaylibColor())",
          "summary": "Draw sphere"
        },
        {
          "name": "DrawSphereWires",
          "signature": "void DrawSphereWires(Vector3 centerPos, float radius, int rings, int slices, Color color)",
          "body": "Raylib6Native.DrawSphereWires(centerPos, radius, rings, slices, color.ToRaylibColor())",
          "summary": "Draw sphere wires"
        },
        {
          "name": "DrawLine",
          "signature": "void DrawLine(Vector3 startPos, Vector3 endPos, Color color)",
          "body": "Raylib6Native.DrawLine3D(startPos, endPos, color.ToRaylibColor())",
          "summary": "Draw a line in 3D world space"
        },
        {
          "name": "DrawCylinder",
          "signature": "void DrawCylinder(Vector3 position, float radiusTop, float radiusBottom, float height, int slices, Color color)",
          "body": "Raylib6Native.DrawCylinder(position, radiusTop, radiusBottom, height, slices, color.ToRaylibColor())",
          "summary": "Draw a cylinder/cone"
        },
        {
          "name": "DrawGrid",
          "signature": "void DrawGrid(int slices, float spacing)",
          "body": "Raylib6Native.DrawGrid(slices, spacing)",
          "summary": "Draw a grid (centered at (0, 0, 0))"
        }
      ]
    },
    {
      "name": "Textures",
      "namespace": "Novolis.Raylib.Rendering",
      "folder": "Rendering",
      "typeSummary": "Texture load, draw, and unload helpers.",
      "usings": [
        "System.Drawing",
        "System.Numerics",
        "Novolis.Raylib.Interop"
      ],
      "methods": [
        {
          "name": "Load",
          "signature": "Texture Load(string fileName)",
          "body": "Texture.FromNative(Raylib6Native.LoadTexture(fileName))",
          "summary": "Load texture from file into GPU memory (VRAM)"
        },
        {
          "name": "Unload",
          "signature": "void Unload(Texture texture)",
          "body": "Raylib6Native.UnloadTexture(texture.Native)",
          "summary": "Unload texture from GPU memory (VRAM)"
        },
        {
          "name": "IsValid",
          "signature": "bool IsValid(Texture texture)",
          "body": "Raylib6Native.IsTextureValid(texture.Native)",
          "summary": "Check if a texture is valid (loaded in GPU)"
        },
        {
          "name": "Draw",
          "signature": "void Draw(Texture texture, int posX, int posY, Color tint)",
          "body": "Raylib6Native.DrawTexture(texture.Native, posX, posY, tint.ToRaylibColor())",
          "summary": "Draw a Texture2D"
        },
        {
          "name": "DrawPro",
          "signature": "void DrawPro(Texture texture, RectangleF source, RectangleF dest, Vector2 origin, float rotation, Color tint)",
          "body": "Raylib6Native.DrawTexturePro(texture.Native, source, dest, origin, rotation, tint.ToRaylibColor())",
          "summary": "Draw a part of a texture defined by a rectangle with \u0027pro\u0027 parameters"
        }
      ]
    },
