<Project>
  <Import Project="$(MSBuildThisFileDirectory)version.props" Condition="Exists('$(MSBuildThisFileDirectory)version.props')" />
  <Import Project="$(MSBuildThisFileDirectory)Novolis.Raylib.Documentation.props" />

  <PropertyGroup Label="Novolis.Raylib NuGet metadata">
    <Authors>Novolis</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <!-- PackageProjectUrl: per-package README link set in src/Directory.Build.props (GPR shows repo README on package pages). -->
    <RepositoryUrl>https://github.com/novolis/novolis-raylib</RepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PackageTags>raylib;raygui;interop;graphics;gamedev</PackageTags>
  </PropertyGroup>
</Project>
