<Project>
  <!-- Copy RID native assets from the nupkg (not repo build output paths). -->
  <Target Name="CopyNovolisRaylibNativeAssets" AfterTargets="Build">
    <ItemGroup>
      <_NovolisRaylibNativeRuntime Include="$(MSBuildThisFileDirectory)..\runtimes\win-x64\native\*" Condition="$([MSBuild]::IsOSPlatform('Windows'))" />
      <_NovolisRaylibNativeRuntime Include="$(MSBuildThisFileDirectory)..\runtimes\linux-x64\native\*" Condition="$([MSBuild]::IsOSPlatform('Linux'))" />
      <_NovolisRaylibNativeRuntime Include="$(MSBuildThisFileDirectory)..\runtimes\osx-x64\native\*" Condition="$([MSBuild]::IsOSPlatform('OSX'))" />
    </ItemGroup>
    <Copy
      SourceFiles="@(_NovolisRaylibNativeRuntime)"
      DestinationFolder="$(OutputPath)"
      SkipUnchangedFiles="true"
      Condition="'@(_NovolisRaylibNativeRuntime)' != ''" />
  </Target>
</Project>
