<Project>
  <Target Name="CopyNovolisRayguiNativeAssets" AfterTargets="Build">
    <ItemGroup>
      <_NovolisRayguiNativeRuntime Include="$(MSBuildThisFileDirectory)..\runtimes\win-x64\native\*" Condition="$([MSBuild]::IsOSPlatform('Windows'))" />
      <_NovolisRayguiNativeRuntime Include="$(MSBuildThisFileDirectory)..\runtimes\linux-x64\native\*" Condition="$([MSBuild]::IsOSPlatform('Linux'))" />
      <_NovolisRayguiNativeRuntime Include="$(MSBuildThisFileDirectory)..\runtimes\osx-x64\native\*" Condition="$([MSBuild]::IsOSPlatform('OSX'))" />
    </ItemGroup>
    <Copy
      SourceFiles="@(_NovolisRayguiNativeRuntime)"
      DestinationFolder="$(OutputPath)"
      SkipUnchangedFiles="true"
      Condition="'@(_NovolisRayguiNativeRuntime)' != ''" />
  </Target>
</Project>
