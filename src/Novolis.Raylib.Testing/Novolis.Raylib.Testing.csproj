<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="$(MSBuildThisFileDirectory)..\..\build\Novolis.Raylib.Packaging.props" />

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <IsTestProject>false</IsTestProject>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Novolis.Raylib.Testing</RootNamespace>
    <AssemblyName>Novolis.Raylib.Testing</AssemblyName>
    <PackageId>Novolis.Raylib.Testing</PackageId>
    <IsPackable>true</IsPackable>
    <Description>Offscreen raylib test harness and debug helpers (optional; for test projects only).</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="TUnit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Novolis.Raylib.Capture\Novolis.Raylib.Capture.csproj" />
    <ProjectReference Include="..\Novolis.Raylib\Novolis.Raylib.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Novolis.Raylib.Golden" />
  </ItemGroup>

</Project>
